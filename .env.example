# clagentic:triage environment variables
# Copy to .env and fill in values. Never commit .env.
# All vars follow the clagentic CLI Naming Standard: CLAGENTIC_TRIAGE_* prefix.

# GitHub personal access token (needs: issues:read, pull_requests:read, issues:write if auto-actions enabled)
CLAGENTIC_TRIAGE_GITHUB_TOKEN=

# Source adapter (github | gitlab | forgejo)
CLAGENTIC_TRIAGE_ADAPTER=github

# Org or user to watch (leave blank to use repos list only)
CLAGENTIC_TRIAGE_ORG=

# Comma-separated repos to watch (owner/repo format). Use * for all repos in org.
CLAGENTIC_TRIAGE_REPOS=*

# ---------------------------------------------------------------------------
# LLM runner and model
#
# RUNNER selects the backend:
#   claude-cli          — default; spawns the claude CLI subprocess
#   anthropic-api       — direct HTTP to api.anthropic.com
#   openai-compatible   — any OpenAI-compatible server (set RUNNER_URL)
#   clagentic-router    — clagentic:router service (set RUNNER_URL)
#
# MODEL is the model identifier passed to the selected runner.
# RUNNER_URL is required for openai-compatible and clagentic-router.
# ---------------------------------------------------------------------------
CLAGENTIC_TRIAGE_RUNNER=claude-cli
CLAGENTIC_TRIAGE_MODEL=claude-sonnet-4-5
# CLAGENTIC_TRIAGE_RUNNER_URL=http://localhost:4200

# API keys for non-CLI runners — the actual secret values read at call time.
# runner_api_key_env in config names which variable to read; defaults below.
# ANTHROPIC_API_KEY=       # used by runner: anthropic-api
# OPENAI_API_KEY=          # used by runner: openai-compatible
# CLAGENTIC_ROUTER_TOKEN=  # used by runner: clagentic-router (optional)

# Confidence threshold below which verdicts always go to the HITL queue (0.0–1.0)
CLAGENTIC_TRIAGE_CONFIDENCE_THRESHOLD=0.7

# Comma-separated action classes to auto-approve without human review
# Options: approve, respond, request_changes, close, dispatch, escalate
# Leave empty for fully human-in-the-loop (recommended to start)
CLAGENTIC_TRIAGE_AUTO_APPROVE=

# Webhook secret for inbound GitHub webhook events (optional, for real-time mode)
CLAGENTIC_TRIAGE_WEBHOOK_SECRET=
