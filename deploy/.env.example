# deploy/.env.example — installer configuration knobs
#
# These vars control WHERE and HOW deploy/install.sh installs the service.
# They are separate from the app's own runtime config (see the root
# .env.example / docs/CONFIG.md) — this file is about the installer/systemd
# layer, not the triage pipeline's behavior.
#
# Copy to deploy/.env (or export in the shell that runs install.sh) and
# customize. Never commit a filled-in copy — every value here defaults to
# something generic; nothing is operator-specific out of the box.

# Absolute path where the service checkout/runtime lives. install.sh clones
# or updates a git checkout here.
CLAGENTIC_TRIAGE_INSTALL_DIR=/opt/clagentic-triage

# Git remote and ref/branch to install/update from.
CLAGENTIC_TRIAGE_GIT_REMOTE=https://github.com/clagentic/clagentic-triage
CLAGENTIC_TRIAGE_GIT_REF=main

# systemd service name (unit file becomes ${SERVICE_NAME}.service) and the
# unix user/group the service runs as. The installer does NOT create the
# user — provision it separately (e.g. `useradd --system --no-create-home
# clagentic-triage`) before running install.sh, or set these to an existing
# service account.
CLAGENTIC_TRIAGE_SERVICE_NAME=clagentic-triage
CLAGENTIC_TRIAGE_RUN_USER=clagentic-triage
CLAGENTIC_TRIAGE_RUN_GROUP=clagentic-triage

# Directory systemd unit files are installed into. /etc/systemd/system is
# standard for a system-wide service; override for a user-unit or
# non-standard systemd layout.
CLAGENTIC_TRIAGE_SYSTEMD_UNIT_DIR=/etc/systemd/system

# Path to the app's runtime environment file (referenced by the rendered
# systemd unit's EnvironmentFile=). This is where CLAGENTIC_TRIAGE_GITHUB_TOKEN
# etc. (see root .env.example) actually live on the deploy host. The
# installer does not create or populate this file's contents.
CLAGENTIC_TRIAGE_ENV_FILE=/etc/clagentic-triage/triage.env

# Path to the node binary used by the rendered run-wrapper. Override if node
# is not on the default PATH resolved for the systemd service user (systemd
# services often see a minimal PATH).
CLAGENTIC_TRIAGE_NODE_BIN=/usr/bin/node

# Set to 1 to force reinstall/restart even when the installed revision
# already matches the target ref (bypasses the idempotency gate).
CLAGENTIC_TRIAGE_FORCE_UPDATE=0

# Set to 1 to skip `npm ci` (e.g. air-gapped host with deps pre-vendored).
CLAGENTIC_TRIAGE_SKIP_NPM_CI=0

# Set to 1 to skip enabling/starting the systemd unit — useful for dry runs
# or environments where systemd is managed out-of-band.
CLAGENTIC_TRIAGE_SKIP_SYSTEMD=0
