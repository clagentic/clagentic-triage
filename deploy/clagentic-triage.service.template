# clagentic-triage.service — systemd unit TEMPLATE
#
# This is a template, not a literal unit file. Placeholders (@@NAME@@) are
# substituted by deploy/install.sh at install time from env-driven config
# (see deploy/.env.example). Never commit a rendered unit with operator-
# specific values — this file must stay generic so the repo is safe to
# publish and reuse on any host.
#
# Rendered output is written to:
#   ${SYSTEMD_UNIT_DIR}/${SERVICE_NAME}.service   (default: /etc/systemd/system)

[Unit]
Description=clagentic:triage — LLM-powered issue/PR triage watch service
Documentation=https://github.com/clagentic/clagentic-triage
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@@RUN_USER@@
Group=@@RUN_GROUP@@
WorkingDirectory=@@INSTALL_DIR@@
EnvironmentFile=-@@ENV_FILE@@
ExecStart=@@RUN_WRAPPER_PATH@@
Restart=on-failure
RestartSec=5
# Give in-flight LLM calls / dispatcher HTTP calls time to finish on stop.
TimeoutStopSec=30

# Hardening — conservative defaults; relax only if a specific integration
# (e.g. a local socket dependency) requires it.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only

[Install]
WantedBy=multi-user.target
